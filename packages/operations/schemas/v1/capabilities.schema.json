{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cork.tech/operations/v1/capabilities.schema.json",
  "title": "Cork capability inventory version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "coreBuild",
    "capabilities",
    "callableCapabilityIds"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cork.capabilities/v1"
    },
    "coreBuild": {
      "$ref": "#/$defs/coreBuild"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      }
    },
    "callableCapabilityIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "uint": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "coreBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageVersion", "sourceCommit", "schemaDigest"],
      "properties": {
        "packageVersion": {
          "type": "string",
          "minLength": 1
        },
        "sourceCommit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "schemaDigest": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "activationBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deploymentId", "generation"],
      "properties": {
        "deploymentId": {
          "type": "string",
          "minLength": 1
        },
        "generation": {
          "$ref": "#/$defs/uint"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deploymentId", "generation", "status"],
      "properties": {
        "deploymentId": {
          "type": "string",
          "minLength": 1
        },
        "generation": {
          "$ref": "#/$defs/uint"
        },
        "status": {
          "enum": ["staged", "active", "retired", "emergency-disabled"]
        }
      }
    },
    "unavailableReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "remediation"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilityId",
        "version",
        "specified",
        "commonProfileDigest",
        "capabilityProfileDigest",
        "vectorSetDigest",
        "implemented",
        "activated",
        "healthy",
        "callable"
      ],
      "properties": {
        "capabilityId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "specified": {
          "const": true
        },
        "commonProfileDigest": {
          "$ref": "#/$defs/sha256"
        },
        "capabilityProfileDigest": {
          "$ref": "#/$defs/sha256"
        },
        "vectorSetDigest": {
          "$ref": "#/$defs/sha256"
        },
        "implemented": {
          "type": "boolean"
        },
        "activated": {
          "type": "boolean"
        },
        "healthy": {
          "type": "boolean"
        },
        "callable": {
          "type": "boolean"
        },
        "operatorBinding": {
          "$ref": "#/$defs/activationBinding"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "unavailableReason": {
          "$ref": "#/$defs/unavailableReason"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "activated": {
                "const": true
              }
            },
            "required": ["activated"]
          },
          "then": {
            "required": ["operatorBinding", "evidence"],
            "properties": {
              "evidence": {
                "properties": {
                  "status": {
                    "const": "active"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "implemented": {
                "const": true
              },
              "activated": {
                "const": true
              },
              "healthy": {
                "const": true
              }
            },
            "required": ["implemented", "activated", "healthy"]
          },
          "then": {
            "properties": {
              "callable": {
                "const": true
              }
            },
            "not": {
              "required": ["unavailableReason"]
            }
          },
          "else": {
            "required": ["unavailableReason"],
            "properties": {
              "callable": {
                "const": false
              }
            }
          }
        }
      ]
    }
  }
}
