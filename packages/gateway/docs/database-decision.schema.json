{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cork.tech/schemas/gateway/database-decision.v1.schema.json",
  "title": "DatabaseDecisionV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "status",
    "recordSchemaVersion",
    "engine",
    "durability",
    "transaction",
    "clockAndLeaseAuthority",
    "migrationAndRollback",
    "productionLikeEvidence",
    "approvedBy",
    "approvedAt",
    "validUntil",
    "artifactDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "cork.database-decision/v1"
    },
    "decisionId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "approved", "rejected"]
    },
    "recordSchemaVersion": {
      "const": "cork.submission-record/v1"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "minimumVersion"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "minimumVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "durability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "recoveryPointObjective", "recoveryTimeObjective"],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "recoveryPointObjective": {
          "type": "string",
          "minLength": 1
        },
        "recoveryTimeObjective": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolationLevel",
        "atomicCreatePattern",
        "compareAndSetPattern"
      ],
      "properties": {
        "isolationLevel": {
          "type": "string",
          "minLength": 1
        },
        "atomicCreatePattern": {
          "type": "string",
          "minLength": 1
        },
        "compareAndSetPattern": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clockAndLeaseAuthority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clockSource", "leaseExpiryAuthority"],
      "properties": {
        "clockSource": {
          "type": "string",
          "minLength": 1
        },
        "leaseExpiryAuthority": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "migrationAndRollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["migrationPosture", "rollbackPosture"],
      "properties": {
        "migrationPosture": {
          "type": "string",
          "minLength": 1
        },
        "rollbackPosture": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "productionLikeEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidenceId", "evidenceDigest"],
        "properties": {
          "evidenceId": {
            "type": "string",
            "minLength": 1
          },
          "evidenceDigest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    },
    "approvedBy": {
      "type": "string",
      "minLength": 1
    },
    "approvedAt": {
      "type": "integer",
      "minimum": 0
    },
    "validUntil": {
      "type": "integer",
      "minimum": 0
    },
    "artifactDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
