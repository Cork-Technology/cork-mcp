{
  "name": "@corkprotocol/operations-node",
  "version": "0.1.0",
  "description": "Node-only raw source and provider observation adapters for Cork operations.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@corkprotocol/operations": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "22.16.0",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
